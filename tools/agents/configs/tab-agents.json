{
  "description": "Agent-to-tab mapping. Each agent researches data that feeds one or more dashboard tabs.",
  "agents": [
    {
      "id": "exchange-rates",
      "label": "Exchange Rates",
      "tabIds": ["overview", "compare", "manage"],
      "promptFile": "prompts/exchange-rates.md",
      "updateFrequency": "monthly",
      "targetFiles": ["data/locations/*/location.json"],
      "targetPaths": ["$.exchangeRates.optimistic", "$.exchangeRates.pessimistic", "$.exchangeRates.mid", "$.exchangeRate"],
      "dependsOn": [],
      "parallel": false,
      "locationsScope": "eur-all"
    },
