{
  "name": "retirement-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx --watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:shared": "cd shared && npx vitest run",
    "typecheck": "tsc --noEmit",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "tailscale:serve": "bash tools/tailscale-serve.sh",
    "tailscale:funnel": "bash tools/tailscale-serve.sh --funnel",
    "tailscale:stop": "bash tools/tailscale-serve.sh --stop"
  },
  "imports": {
    "#shared/*": "./shared/*"
  },
  "dependencies": {
    "@clerk/fastify": "^3.1.4",
    "@fastify/cookie": "^10.0.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^12.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@prisma/client": "^6.0.0",
    "@sentry/node": "^10.45.0",
    "dotenv": "^16.4.0",
    "fastify": "^5.0.0",
    "stripe": "^20.4.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "prisma": "^6.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0"
  }
}
