# ─── Database ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://retirement:<GENERATE_STRONG_PASSWORD>@localhost:5432/retirement_saas
POSTGRES_DB=retirement_saas
POSTGRES_USER=retirement
POSTGRES_PASSWORD=<GENERATE_STRONG_PASSWORD>

# ─── Redis ────────────────────────────────────────────────────────────────
# Generate a strong password: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
REDIS_URL=redis://:<GENERATE_STRONG_PASSWORD>@localhost:6379
REDIS_PASSWORD=<GENERATE_STRONG_PASSWORD>

# ─── Clerk Authentication ─────────────────────────────────────────────────
# Get from https://dashboard.clerk.com → API Keys
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...

# ─── Stripe Billing ──────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_BASIC=price_...
STRIPE_PRICE_PREMIUM=price_...

# ─── Encryption ──────────────────────────────────────────────────────────
# 64-char hex key for AES-256-GCM at-rest encryption of financial data
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_MASTER_KEY=

# ─── CORS ────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Supports multiple frontends connecting to this API
CORS_ORIGIN=http://localhost:5173,http://localhost:8080
APP_URL=http://localhost:8080

# ─── Observability ────────────────────────────────────────────────────────
SENTRY_DSN=

# ─── Server ──────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
API_PORT=3000
# Optional: number of api replicas behind the compose stack (default 1).
API_REPLICAS=1
# Host port for the dashboard nginx (default 8080). The dashboard container
# always listens on 8080 internally — this only changes the host mapping.
DASHBOARD_PORT=8080

# ─── Tailscale Funnel sidecar (Phase 3.4b) ──────────────────────────────
# Reusable, pre-approved auth key from https://login.tailscale.com/admin/settings/keys
# Tagged tag:funnel-dashboard (must have nodeAttrs:["funnel"] in tailnet ACL).
# Generate fresh per deploy host; back up alongside other secrets.
TS_AUTHKEY_FUNNEL_DASHBOARD=tskey-auth-...

# ─── Dev Auth Bypass ──────────────────────────────────────────────────────
# Set DEV_AUTH_BYPASS=1 in local dev to auto-create/sign-in dev@localhost (admin tier)
# when requests arrive without an Authorization header. Requires NODE_ENV=development.
# NEVER set this in staging/prod — even if NODE_ENV is misconfigured, this guard keeps the
# bypass path closed. Defaults to unset (auth required).
DEV_AUTH_BYPASS=

# ─── Shodan (pentest container) ──────────────────────────────────────────
# Used by `pentest/run-scan.sh` for runtime + supply-chain attack-surface
# checks. Free-tier account is fine (~100 queries/month). Sign up at
# https://shodan.io and copy the API key from My Account.
# Only required when running pentest scans; safe to leave unset otherwise.
SHODAN_API_KEY=
