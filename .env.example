# ─── Database ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://retirement:password@localhost:5432/retirement_saas
POSTGRES_DB=retirement_saas
POSTGRES_USER=retirement
POSTGRES_PASSWORD=<GENERATE_STRONG_PASSWORD>

# ─── Redis ────────────────────────────────────────────────────────────────
REDIS_URL=redis://:changeme@localhost:6379
REDIS_PASSWORD=changeme

# ─── Clerk Authentication ─────────────────────────────────────────────────
# Get from https://dashboard.clerk.com → API Keys
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...

# ─── Stripe Billing ──────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_BASIC=price_...
STRIPE_PRICE_PREMIUM=price_...

# ─── Encryption ──────────────────────────────────────────────────────────
# 64-char hex key for AES-256-GCM at-rest encryption of financial data
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_MASTER_KEY=

# ─── CORS ────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Supports multiple frontends connecting to this API
CORS_ORIGIN=http://localhost:5173,http://localhost:8080
APP_URL=http://localhost:8080

# ─── Observability ────────────────────────────────────────────────────────
SENTRY_DSN=

# ─── Server ──────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
API_PORT=3000

# ─── Dev Auth Bypass ──────────────────────────────────────────────────────
# Set DEV_AUTH_BYPASS=1 in local dev to auto-create/sign-in dev@localhost (admin tier)
# when requests arrive without an Authorization header. Requires NODE_ENV=development.
# NEVER set this in staging/prod — even if NODE_ENV is misconfigured, this guard keeps the
# bypass path closed. Defaults to unset (auth required).
DEV_AUTH_BYPASS=
