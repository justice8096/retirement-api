generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Identity ───────────────────────────────────────────────────────────────

enum SubscriptionTier {
  free
  basic
  premium
  admin
}

// ─── Contribution & Feature Unlock Enums ────────────────────────────────────

enum ContributionType {
  cost_correction
  new_location
  review_rating
  supplemental_data
}

enum ContributionStatus {
  pending
  approved
  rejected
}

enum FeatureSet {
  basic
  premium
}

enum UnlockReason {
  contribution
  purchase
  grandfathered
  admin_grant
}

enum GrantedReason {
  purchase
  grandfathered
  admin_grant
}

model User {
  id              String           @id @default(uuid())
  authProviderId  String           @unique @map("auth_provider_id")
  email           String           @unique
  displayName     String?          @map("display_name")
  tier            SubscriptionTier @default(free)
  stripeCustomerId String?        @map("stripe_customer_id")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  household        HouseholdProfile?
  financialSettings UserFinancialSettings?
  withdrawalStrategy UserWithdrawalStrategy?
  preferences      UserPreferences?
  customLocations  UserCustomLocation[]
  locationOverrides UserLocationOverride[]
  scenarios        UserScenario[]
  groceryData      UserGroceryData?
  releasePurchases UserReleasePurchase[]
  contributions    Contribution[]
  badges           UserBadge[]
  featureUnlocks   UserFeatureUnlock[]
  brokerageFees    UserBrokerageFees?

  @@map("users")
}

// ─── Household ──────────────────────────────────────────────────────────────

model HouseholdProfile {
  id                String   @id @default(uuid())
  userId            String   @unique @map("user_id")
  adultsCount       Int      @default(2) @map("adults_count")
  targetAnnualIncome String?  @map("target_annual_income") // Encrypted at rest (AES-256-GCM)
  planningStartYear Int      @default(2026) @map("planning_start_year")
  planningYears     Int      @default(40) @map("planning_years")
  requirements      Json?    // ["gigabit-internet", "warm-winters", "dog-friendly"]
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user    User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  members HouseholdMember[]
  pets    HouseholdPet[]

  @@map("household_profiles")
}

model HouseholdMember {
  id             String  @id @default(uuid())
  householdId    String  @map("household_id")
  role           String  @default("primary") // 'primary', 'spouse', 'dependent'
  dependentType  String? @map("dependent_type") // 'adult' | 'child' — only when role='dependent'
  name           String?
  birthYear      Int     @map("birth_year")
  ssPia          String?  @map("ss_pia")       // Monthly PIA at FRA — encrypted at rest (AES-256-GCM)
  ssFra          Int?    @map("ss_fra")        // Full Retirement Age
  ssClaimAge     Int?    @map("ss_claim_age")
  sortOrder      Int     @default(0) @map("sort_order")

  household HouseholdProfile @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([householdId])
  @@map("household_members")
}

model HouseholdPet {
  id               String  @id @default(uuid())
  householdId      String  @map("household_id")
  name             String? // Pet name (e.g., "Luna")
  type             String  @default("dog") // 'dog' | 'cat' | 'bird' | 'rabbit' | 'fish' | 'horse' | 'reptile'
  breed            String?
  size             String? // 'small', 'medium', 'large' — kept for backward compat
  weight           Int?    // Exact weight in pounds (dogs, horses)
  weightTier       String? @map("weight_tier") // Derived: 'small' | 'medium' | 'large' | 'giant' (dogs only)
  feedingMode      String? @map("feeding_mode") // 'commercial' | 'homemade' (dogs/cats only)
  birthYear        Int     @map("birth_year")
  expectedLifespan Int     @default(12) @map("expected_lifespan")
  sortOrder        Int     @default(0) @map("sort_order")

  household HouseholdProfile @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([householdId])
  @@map("household_pets")
}

// ─── Financial Settings ─────────────────────────────────────────────────────

model UserFinancialSettings {
  userId           String   @id @map("user_id")
  portfolioBalance String   @default("500000") @map("portfolio_balance") // Encrypted at rest (AES-256-GCM)
  fxDriftEnabled   Boolean  @default(true) @map("fx_drift_enabled")
  fxDriftAnnualRate Decimal @default(0.01) @map("fx_drift_annual_rate")
  ssCutEnabled     Boolean  @default(true) @map("ss_cut_enabled")
  ssCutYear        Int      @default(2033) @map("ss_cut_year")
  ssCola           Decimal  @default(2.5) @map("ss_cola")

  // ─── Asset Allocation ──────────────────────────────────────────────
  equityPct         Decimal  @default(0.60) @map("equity_pct")
  bondPct           Decimal  @default(0.30) @map("bond_pct")
  cashPct           Decimal  @default(0.10) @map("cash_pct")
  intlPct           Decimal  @default(0.20) @map("intl_pct")

  // ─── Return Assumptions ────────────────────────────────────────────
  expectedReturn    Decimal  @default(0.07) @map("expected_return")
  expectedInflation Decimal  @default(0.025) @map("expected_inflation")

  // ─── FIRE Settings ─────────────────────────────────────────────────
  retirementPath    String   @default("traditional") @map("retirement_path") // traditional | fire | explore
  fireTargetAge     Int?     @map("fire_target_age")
  annualSavings     Decimal? @map("annual_savings")
  savingsRate       Decimal? @map("savings_rate")

  // ─── Multi-Account Balances (encrypted) ────────────────────────────
  traditionalBalance String? @map("traditional_balance") // Encrypted
  rothBalance        String? @map("roth_balance")        // Encrypted
  taxableBalance     String? @map("taxable_balance")     // Encrypted
  hsaBalance         String? @map("hsa_balance")         // Encrypted

  // ─── Per-Account Load % and Fees % (recurring annual drags) ────────
  // Stored as decimal fractions (0.005 = 0.5%). Client sends whole-% (0.5 = 0.5%).
  traditionalLoadPct Decimal @default(0) @map("traditional_load_pct")
  rothLoadPct        Decimal @default(0) @map("roth_load_pct")
  taxableLoadPct     Decimal @default(0) @map("taxable_load_pct")
  hsaLoadPct         Decimal @default(0) @map("hsa_load_pct")
  traditionalFeesPct Decimal @default(0) @map("traditional_fees_pct")
  rothFeesPct        Decimal @default(0) @map("roth_fees_pct")
  taxableFeesPct     Decimal @default(0) @map("taxable_fees_pct")
  hsaFeesPct         Decimal @default(0) @map("hsa_fees_pct")

  updatedAt        DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_financial_settings")
}

// ─── Withdrawal Strategy ───────────────────────────────────────────────────────

model UserWithdrawalStrategy {
  id                String   @id @default(uuid())
  userId            String   @unique @map("user_id")
  strategyType      String   @default("fixed") @map("strategy_type") // fixed | constant | guardrails | vpw | bucket | floor-ceiling

  // Fixed / Constant Percentage
  withdrawalRate    Decimal  @default(0.04) @map("withdrawal_rate")

  // Guardrails (Guyton-Klinger)
  ceilingRate       Decimal? @map("ceiling_rate")     // e.g., 0.06
  floorRate         Decimal? @map("floor_rate")       // e.g., 0.03
  adjustmentPct     Decimal? @map("adjustment_pct")   // e.g., 0.10 (10% cut/raise)

  // Bucket Strategy
  bucket1Years      Int?     @map("bucket1_years")    // Short-term (cash/bonds)
  bucket2Years      Int?     @map("bucket2_years")    // Medium-term (balanced)
  refillThreshold   Decimal? @map("refill_threshold") // Years of spending before refill

  // Floor-and-Ceiling
  essentialSpending Decimal? @map("essential_spending")
  discretionaryBudget Decimal? @map("discretionary_budget")
  maxDiscretionaryRate Decimal? @map("max_discretionary_rate")

  // Spending Model
  spendingModel     String   @default("level") @map("spending_model") // level | smile | declining | essential-first
  declineRate       Decimal? @map("decline_rate")     // For declining model (e.g., 0.015)

  // Roth Conversion
  rothConversionEnabled Boolean @default(false) @map("roth_conversion_enabled")
  rothConversionAmount  Decimal? @map("roth_conversion_amount") // Annual target
  rothConversionEndAge  Int?    @map("roth_conversion_end_age")

  updatedAt         DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_withdrawal_strategies")
}

// ─── Preferences (replaces ~48 usePersistedState keys) ──────────────────────

model UserPreferences {
  userId      String   @id @map("user_id")
  preferences Json     @default("{}") // Single JSONB blob for all tab state
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

// ─── Custom Locations & Overrides ───────────────────────────────────────────

model UserCustomLocation {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  locationData Json     @map("location_data") // Full location object
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_custom_locations")
}

model UserLocationOverride {
  id                  String   @id @default(uuid())
  userId              String   @map("user_id")
  baseLocationId      String   @map("base_location_id")
  baseLocationVersion Int      @default(1) @map("base_location_version")
  overrides           Json     // Partial cost/field overrides
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, baseLocationId])
  @@index([userId])
  @@map("user_location_overrides")
}

// ─── Saved Scenarios ────────────────────────────────────────────────────────

model UserScenario {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  name         String
  scenarioData Json     @map("scenario_data")
  scenarioType      String   @default("deterministic") @map("scenario_type") // deterministic | monte_carlo | historical
  successRate       Decimal? @map("success_rate")        // 0-100 (Monte Carlo)
  medianBalance     Decimal? @map("median_balance")      // Median ending balance
  p10Balance        Decimal? @map("p10_balance")         // 10th percentile
  p90Balance        Decimal? @map("p90_balance")         // 90th percentile
  simulationRuns    Int?     @map("simulation_runs")     // Number of MC runs
  isFavorite        Boolean  @default(false) @map("is_favorite")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_scenarios")
}

// ─── Grocery Data ───────────────────────────────────────────────────────────

model UserGroceryData {
  userId    String   @id @map("user_id")
  overrides Json     @default("{}")
  lists     Json     @default("{}")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_grocery_data")
}

// ─── Admin-Managed Location Data (replaces JSON files) ──────────────────────

model AdminLocation {
  id           String   @id // e.g., 'france-brittany'
  version      Int      @default(1)
  locationData Json     @map("location_data") // Full location.json content
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Denormalized columns for fast filtering/search at scale (100+ locations)
  name         String   @default("") // Extracted from locationData.name
  country      String   @default("") // Extracted from locationData.country
  region       String   @default("") // Extracted from locationData.region
  currency     String   @default("USD")
  monthlyCostTotal Int  @default(0) @map("monthly_cost_total") // Sum of all typical costs (USD)

  supplements AdminLocationSupplement[]
  history     AdminLocationHistory[]

  @@index([country])
  @@index([region])
  @@index([currency])
  @@index([monthlyCostTotal])
  @@index([name])
  @@map("admin_locations")
}

model AdminLocationSupplement {
  locationId String @map("location_id")
  dataType   String @map("data_type") // 'neighborhoods', 'services', 'inclusion', 'detailed-costs', 'local-info'
  data       Json
  updatedAt  DateTime @updatedAt @map("updated_at")

  location AdminLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@id([locationId, dataType])
  @@index([locationId])
  @@map("admin_location_supplements")
}

model AdminSharedData {
  key       String   @id // 'service-categories', 'inclusion-methodology', 'grocery-defaults', etc.
  data      Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("admin_shared_data")
}

// ─── Webhook Idempotency ─────────────────────────────────────────────────────

model ProcessedEvent {
  eventId     String   @id @map("event_id") // Stripe event ID (e.g., 'evt_xxx')
  eventType   String   @map("event_type")
  processedAt DateTime @default(now()) @map("processed_at")

  @@index([processedAt])
  @@map("processed_events")
}

model AdminLocationHistory {
  id           Int      @id @default(autoincrement())
  locationId   String   @map("location_id")
  version      Int
  locationData Json     @map("location_data")
  changedBy    String?  @map("changed_by")
  changedAt    DateTime @default(now()) @map("changed_at")

  location AdminLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@index([locationId, version])
  @@map("admin_location_history")
}

// ─── Data Releases (pay-per-update) ─────────────────────────────────────────

model DataRelease {
  id            String    @id @default(uuid())
  version       Int       @unique
  title         String    // e.g. "Spring 2026 Data Update"
  description   String?
  priceUsd      Int       @default(0) @map("price_usd") // Price in cents (0 = free)
  stripePriceId String?   @map("stripe_price_id")
  publishedAt   DateTime? @map("published_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  purchases UserReleasePurchase[]

  @@index([publishedAt])
  @@map("data_releases")
}

model UserReleasePurchase {
  id            String       @id @default(uuid())
  userId        String       @map("user_id")
  releaseId     String       @map("release_id")
  grantedReason GrantedReason @map("granted_reason")
  createdAt     DateTime     @default(now()) @map("created_at")

  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  release DataRelease @relation(fields: [releaseId], references: [id], onDelete: Cascade)

  @@unique([userId, releaseId])
  @@index([userId])
  @@map("user_release_purchases")
}

// ─── Contributions (earn features by adding data) ───────────────────────────

model Contribution {
  id           String             @id @default(uuid())
  userId       String             @map("user_id")
  type         ContributionType
  status       ContributionStatus @default(pending)
  locationId   String?            @map("location_id") // Related location (optional for new_location type)
  title        String
  data         Json               // Contribution payload (cost corrections, reviews, etc.)
  adminNotes   String?            @map("admin_notes")
  reviewedAt   DateTime?          @map("reviewed_at")
  reviewedBy   String?            @map("reviewed_by")
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([type])
  @@map("contributions")
}

// ─── Badges (cosmetic achievement markers) ──────────────────────────────────

model UserBadge {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  badgeKey  String   @map("badge_key") // founding_member, cost_corrector, data_pioneer, etc.
  awardedAt DateTime @default(now()) @map("awarded_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeKey])
  @@index([userId])
  @@map("user_badges")
}

// ─── Feature Unlocks (separate from badges) ─────────────────────────────────

model UserFeatureUnlock {
  id           String       @id @default(uuid())
  userId       String       @map("user_id")
  featureSet   FeatureSet   @map("feature_set")
  unlockedVia  UnlockReason @map("unlocked_via")
  createdAt    DateTime     @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, featureSet])
  @@index([userId])
  @@map("user_feature_unlocks")
}

// --- Brokerage & Transfer Fees ---

model UserBrokerageFees {
  userId               String   @id @map("user_id")

  // Stock brokerage fees
  brokerageFeePct      Decimal  @default(0.005) @map("brokerage_fee_pct")      // e.g. 0.005 = 0.5%
  brokerageFeeFlat     Decimal  @default(0)     @map("brokerage_fee_flat")     // flat per-trade fee (USD)
  brokerageAnnualFee   Decimal  @default(0)     @map("brokerage_annual_fee")   // annual custody/account fee
  brokerageExpenseRatio Decimal @default(0.002) @map("brokerage_expense_ratio") // fund expense ratio

  // Wire / ACH transfer fees
  wireTransferFeeUsd   Decimal  @default(25)    @map("wire_transfer_fee_usd")  // outgoing wire fee
  wireTransferFeeLocal Decimal  @default(0)     @map("wire_transfer_fee_local")// receiving bank fee in local currency
  achTransferFee       Decimal  @default(0)     @map("ach_transfer_fee")       // domestic ACH fee

  // Currency exchange fees
  fxSpreadPct          Decimal  @default(0.01)  @map("fx_spread_pct")          // bank/broker FX spread
  fxFixedFee           Decimal  @default(0)     @map("fx_fixed_fee")           // flat FX conversion fee (USD)
  fxProvider           String   @default("bank") @map("fx_provider")           // bank | wise | ofx | xe | other

  // Preferred currency (derived from selected city)
  localCurrency        String   @default("USD") @map("local_currency")
  manualExchangeRate   Decimal? @map("manual_exchange_rate")                   // user override for FX rate

  updatedAt            DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_brokerage_fees")
}
